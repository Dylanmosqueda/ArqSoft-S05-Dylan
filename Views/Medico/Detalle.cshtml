@model CitasApp.Models.Medico
@* Ajusta la directiva @model según el namespace exacto de tu entidad Medico *@

<style>
    /* Estilos Clínicos Coherentes con el Portal */
    body {
        background-color: #f8fafc !important;
        color: #1e293b;
        font-family: 'Segoe UI', -apple-system, BlinkMacSystemFont, Roboto, sans-serif;
    }

        body::after {
            content: "";
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
            background: linear-gradient(90deg, #0284c7, #0d9488);
            z-index: 9999;
            pointer-events: none;
        }

    /* Enlace de retorno */
    .back-link {
        color: #0284c7;
        text-decoration: none;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        margin-bottom: 25px;
        transition: color 0.2s;
    }

        .back-link:hover {
            color: #0369a1;
            text-decoration: underline;
        }

    /* Contenedores estilo ficha médica */
    .clinic-card {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        padding: 30px;
        margin-bottom: 30px;
    }

    .section-title {
        color: #0f172a;
        font-size: 1.25rem;
        font-weight: 700;
        border-bottom: 2px solid #0284c7; /* Línea azul para doctores */
        padding-bottom: 8px;
        margin-top: 10px;
        margin-bottom: 20px;
    }

    .avatar-container {
        text-align: center;
        border-bottom: 1px solid #f1f5f9;
        padding-bottom: 20px;
        margin-bottom: 20px;
    }

    .badge-specialty {
        background-color: #0284c7;
        color: white;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
    }

    /* Tipografía de etiquetas y valores */
    .detail-label {
        font-size: 0.8rem;
        text-transform: uppercase;
        color: #64748b;
        font-weight: 700;
        margin-bottom: 3px;
        letter-spacing: 0.5px;
    }

    .detail-value {
        font-size: 1rem;
        color: #1e293b;
        margin-bottom: 18px;
        font-weight: 500;
    }

    /* Botones */
    .btn-medical {
        background-color: #0284c7;
        color: white;
        border: 1px solid #0284c7;
        border-radius: 4px;
        font-weight: 600;
        transition: background-color 0.2s;
    }

        .btn-medical:hover {
            background-color: #0369a1;
            color: white;
        }

    .btn-outline-danger-medical {
        color: #ef4444;
        border: 1px solid #fca5a5;
        background-color: transparent;
        font-weight: 600;
        border-radius: 4px;
        transition: all 0.2s;
    }

        .btn-outline-danger-medical:hover {
            background-color: #fef2f2;
            border-color: #ef4444;
        }
</style>

<div class="container py-4">
    <!-- Botón de regreso -->
    <a asp-action="Index" class="back-link">
        &larr; Volver al Directorio Médico
    </a>

    <div class="row">
        <!-- Columna Izquierda: Foto de Perfil y Datos Principales -->
        <div class="col-lg-4">
            <div class="clinic-card text-center">
                <div class="avatar-container">
                    <!-- Se lee mediante reflexión para evitar errores si tu entidad no define Foto o ImagenUrl -->
                    <img src="@(Model.GetType().GetProperty("ImagenUrl") != null ? Model.GetType().GetProperty("ImagenUrl").GetValue(Model) : "https://cdn-icons-png.flaticon.com/512/3774/3774299.png")"
                         alt="Médico"
                         style="width: 140px; height: 140px; object-fit: contain; border-radius: 50%; background-color: #f8fafc; border: 3px solid #e2e8f0; padding: 5px;" />

                    <h3 class="mt-3 mb-2 font-weight-bold" style="color: #0f172a;">@Model.Nombre</h3>
                    <span class="badge-specialty">@Model.Especialidad</span>
                </div>

                <div class="text-start">
                    <div class="detail-label">Número de Colegiado</div>
                    <div class="detail-value" style="font-weight: 700; color: #0284c7;">
                        @* Adaptación segura de lectura dinámica para NumeroLicencia o NumeroColegiado *@
                        @(Model.GetType().GetProperty("NumeroLicencia") != null
                            ? Model.GetType().GetProperty("NumeroLicencia").GetValue(Model)
                            : (Model.GetType().GetProperty("NumeroColegiado") != null
                                ? Model.GetType().GetProperty("NumeroColegiado").GetValue(Model)
                                : "Sin registrar"))
                    </div>

                    <div class="detail-label">Código de Empleado</div>
                    <div class="detail-value">#@Model.Id</div>
                </div>
            </div>
        </div>

        <!-- Columna Derecha: Información Profesional y de Contacto -->
        <div class="col-lg-8">
            <div class="clinic-card">
                <h3 class="section-title">Información de Contacto</h3>

                <div class="row">
                    <div class="col-md-6">
                        <div class="detail-label">Correo Electrónico Institucional</div>
                        <div class="detail-value">
                            @(Model.GetType().GetProperty("Email") != null ? Model.GetType().GetProperty("Email").GetValue(Model) : "Sin registrar")
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="detail-label">Teléfono de Oficina</div>
                        <div class="detail-value">
                            @(Model.GetType().GetProperty("Telefono") != null ? Model.GetType().GetProperty("Telefono").GetValue(Model) : "Sin registrar")
                        </div>
                    </div>
                </div>

                <h3 class="section-title">Ubicación y Horarios</h3>

                <div class="row">
                    <div class="col-md-6">
                        <div class="detail-label">Consultorio / Consultorio N°</div>
                        <div class="detail-value" style="font-weight: 600;">
                            @(Model.GetType().GetProperty("Consultorio") != null ? Model.GetType().GetProperty("Consultorio").GetValue(Model) : "No asignado")
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="detail-label">Horario de Atención</div>
                        <div class="detail-value">
                            @(Model.GetType().GetProperty("HorarioAtencion") != null ? Model.GetType().GetProperty("HorarioAtencion").GetValue(Model) : "Lunes a Viernes (08:00 - 16:00)")
                        </div>
                    </div>
                </div>

                <h3 class="section-title">Perfil Profesional</h3>

                <div class="row">
                    <div class="col-12">
                        <div class="detail-label">Resumen / Descripción de Especialidad</div>
                        <div class="detail-value text-muted" style="line-height: 1.6; font-size: 0.95rem; white-space: pre-line;">
                            @(Model.GetType().GetProperty("Descripcion") != null ? Model.GetType().GetProperty("Descripcion").GetValue(Model) : "No se ha agregado un perfil o descripción adicional para este especialista médico.")
                        </div>
                    </div>
                </div>

                <!-- Acciones del Registro -->
                <div class="d-flex justify-content-end gap-2 mt-4 pt-4 border-top" style="border-top: 1px solid #f1f5f9 !important;">
                    <a asp-action="Editar" asp-route-id="@Model.Id" class="btn btn-medical px-4 py-2" style="margin-right: 10px;">
                        Editar Información
                    </a>
                    <a asp-action="Eliminar" asp-route-id="@Model.Id" class="btn btn-outline-danger-medical px-4 py-2">
                        Dar de Baja
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>