@model IEnumerable<CitasApp.Models.Medico>

<style>
    body {
        background-color: #0a0a0a !important;
        color: #d1c7bd;
        font-family: 'Courier New', Courier, monospace;
    }

    .clinic-header-container {
        position: relative;
        height: 220px;
        overflow: hidden;
        margin-bottom: 30px;
        background: linear-gradient(135deg, #050505 0%, #151515 100%);
        border-bottom: 4px solid #8b0000;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.9);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        border-radius: 4px;
    }

    .clinic-pulse-effect {
        position: absolute;
        width: 250px;
        height: 250px;
        border-radius: 50%;
        background: radial-gradient(circle at center, rgba(139, 0, 0, 0.3) 0%, rgba(43, 0, 0, 0.1) 50%, transparent 70%);
        animation: pulseWave 3s infinite alternate;
        z-index: 1;
        pointer-events: none;
    }

    @@keyframes pulseWave {
        0% {
            transform: scale(0.9);
            opacity: 0.4;
        }

        100% {
            transform: scale(1.15);
            opacity: 0.8;
        }
    }

    .main-title {
        color: #8b0000;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 2px;
        z-index: 2;
        position: relative;
    }

    .card-doctor {
        background-color: #121212 !important;
        color: #d1c7bd !important;
        border: 2px solid #3a1f1f !important;
        border-radius: 4px !important;
        transition: all 0.3s ease;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.8);
    }

        .card-doctor:hover {
            transform: translateY(-4px);
            box-shadow: 0 0 20px rgba(255, 0, 0, 0.4) !important;
            border-color: #ff0000 !important;
        }

        .card-doctor img {
            filter: grayscale(70%) contrast(125%) brightness(95%);
            background-color: #1a1a1a !important;
            transition: filter 0.3s ease;
        }

        .card-doctor:hover img {
            filter: grayscale(0%) contrast(110%);
        }

    .card-doctor-body {
        background-color: #121212 !important;
        border-top: 3px solid #8b0000;
        border-radius: 0 0 4px 4px;
        padding: 1.5rem;
    }

    .btn-medical {
        background-color: #8b0000;
        color: white;
        border: 1px solid #5a0000;
        border-radius: 2px;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.2s;
    }

        .btn-medical:hover {
            background-color: #ff0000;
            color: black;
            box-shadow: 0 0 10px rgba(255, 0, 0, 0.6);
        }

    .btn-outline-medical {
        color: #ff3333;
        border: 2px solid #8b0000;
        background-color: #1a1a1a;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 1px;
        border-radius: 2px;
        transition: all 0.2s;
    }

        .btn-outline-medical:hover {
            color: black;
            background-color: #ff0000;
            border-color: #ff0000;
            box-shadow: 0 0 15px rgba(255, 0, 0, 0.6);
        }

    /* Escaneo de Espiral Activo */
    .row-laser-scan {
        position: relative;
    }

        .row-laser-scan::after {
            content: "";
            position: absolute;
            top: 50%;
            left: 50%;
            width: 320px;
            height: 320px;
            background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><path d='M 50 50 C 49 47, 53 47, 53 51 C 53 56, 46 56, 45 49 C 44 40, 56 39, 58 49 C 60 62, 41 63, 38 49 C 34 31, 59 28, 63 47 C 67 71, 33 71, 29 48 C 23 18, 67 13, 71 47 C 76 83, 21 82, 16 46' fill='none' stroke='%23ff0000' stroke-width='4' stroke-linecap='round'/></svg>");
            background-size: contain;
            background-repeat: no-repeat;
            opacity: 0;
            pointer-events: none;
            z-index: 10;
            transform: translate(-50%, -50%) scale(0.4) rotate(0deg);
            animation: targetSpiral 9s infinite ease-in-out;
        }

    @@keyframes targetSpiral {
        0% {
            transform: translate(-50%, -50%) scale(0.4) rotate(0deg);
            opacity: 0;
        }

        15% {
            opacity: 0.15;
        }

        50% {
            transform: translate(-50%, -50%) scale(1.2) rotate(360deg);
            opacity: 0.28;
            filter: drop-shadow(0 0 15px rgba(255,0,0,0.6));
        }

        85% {
            opacity: 0.15;
        }

        100% {
            transform: translate(-50%, -50%) scale(0.4) rotate(720deg);
            opacity: 0;
        }
    }
</style>

<div class="clinic-header-container shadow-sm">
    <div class="clinic-pulse-effect"></div>

    <div style="z-index: 2; text-align: center; background: rgba(0,0,0,0.85); padding: 20px 30px; border: 1px solid #3a1f1f; border-radius: 4px;">
        <h1 class="main-title" style="color: #ff0000; text-shadow: 0 0 8px #8b0000; font-size: 2.1rem; margin: 0;">
            DIRECTORIO DE MEDICOS
        </h1>
        <p style="color: #8a8075; font-weight: bold; letter-spacing: 1px; margin-top: 10px; margin-bottom: 0;">
            [ EXPEDIENTES DEL PERSONAL Y ESPECIALIDADES  ]
        </p>
    </div>
</div>

<h1 class="text-center my-4 main-title" style="font-size: 1.6rem; color: #d1c7bd; letter-spacing: 1.5px;">Sujetos Registrados</h1>

<div class="text-center mb-5">
    <a asp-action="Index" class="btn btn-medical btn-sm mx-1 px-4 py-2">Todos</a>
    @if (ViewBag.Especialidades != null)
    {
        foreach (var esp in ViewBag.Especialidades as List<string>)
        {
            <a asp-action="Index" asp-route-especialidad="@esp" class="btn btn-outline-medical btn-sm mx-1 px-3 py-2">@esp</a>
        }
    }
</div>

<div class="row row-laser-scan">
    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card card-doctor h-100 border-0">
                <img src="@(item.GetType().GetProperty("ImagenUrl") != null ? item.GetType().GetProperty("ImagenUrl").GetValue(item) : "https://cdn-icons-png.flaticon.com/512/3774/3774299.png")"
                     class="card-img-top p-4"
                     alt="@item.Nombre"
                     style="height: 180px; object-fit: contain;" />

                <div class="card-doctor-body text-center">
                    <h5 class="card-title fw-bold" style="font-size: 1.2rem; color: #f1f1f1; letter-spacing: 0.5px;">@item.Nombre</h5>

                    <span class="badge mb-3" style="background-color: #5a0000; border: 1px solid #8b0000; font-size: 0.85rem; padding: 6px 12px; border-radius: 2px; text-transform: uppercase; color: #f1f1f1; letter-spacing: 1px;">@item.Especialidad</span>

                    <p class="small text-muted mb-3" style="color: #8a8075 !important;">
                        N° LICENCIA:
                        <strong class="text-danger" style="text-shadow: 0 0 3px rgba(255, 51, 51, 0.2);">
                            @(item.GetType().GetProperty("NumeroLicencia") != null
                                ? item.GetType().GetProperty("NumeroLicencia").GetValue(item)
                                : (item.GetType().GetProperty("NumeroColegiado") != null
                                    ? item.GetType().GetProperty("NumeroColegiado").GetValue(item)
                                    : "N/A"))
                        </strong>
                    </p>

                    <a asp-action="Detalle" asp-route-id="@item.Id" class="btn btn-medical btn-sm w-100 mt-2">
                        Inspeccionar Historial
                    </a>
                </div>
            </div>
        </div>
    }
</div>

<hr style="border-color: #3a1f1f; margin: 40px 0;" />

<div class="text-center mb-5 mt-4 pb-5">
    <a asp-action="Agregar" class="btn btn-outline-medical btn-lg shadow-sm" style="border-width: 2px; font-weight: 700; padding: 12px 30px;">
        + REGISTRAR NUEVO MÉDICO
    </a>
</div>