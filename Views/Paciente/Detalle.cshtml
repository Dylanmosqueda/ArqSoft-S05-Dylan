@model CitasApp.Models.Paciente
@* Ajusta la directiva @model según el namespace exacto de tu entidad Paciente *@

<style>
    /* Estilos Clínicos Coherentes con el Portal */
    body {
        background-color: #f8fafc !important;
        color: #1e293b;
        font-family: 'Segoe UI', -apple-system, BlinkMacSystemFont, Roboto, sans-serif;
    }

        body::after {
            content: "";
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
            background: linear-gradient(90deg, #0284c7, #0d9488);
            z-index: 9999;
            pointer-events: none;
        }

    /* Enlace de retorno */
    .back-link {
        color: #0284c7;
        text-decoration: none;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        margin-bottom: 25px;
        transition: color 0.2s;
    }

        .back-link:hover {
            color: #0369a1;
            text-decoration: underline;
        }

    /* Contenedores estilo ficha médica */
    .clinic-card {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        padding: 30px;
        margin-bottom: 30px;
    }

    .section-title {
        color: #0f172a;
        font-size: 1.25rem;
        font-weight: 700;
        border-bottom: 2px solid #0d9488;
        padding-bottom: 8px;
        margin-top: 10px;
        margin-bottom: 20px;
    }

    .avatar-container {
        text-align: center;
        border-bottom: 1px solid #f1f5f9;
        padding-bottom: 20px;
        margin-bottom: 20px;
    }

    .badge-gender {
        background-color: #0d9488;
        color: white;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
    }

    /* Tipografía de etiquetas y valores */
    .detail-label {
        font-size: 0.8rem;
        text-transform: uppercase;
        color: #64748b;
        font-weight: 700;
        margin-bottom: 3px;
        letter-spacing: 0.5px;
    }

    .detail-value {
        font-size: 1rem;
        color: #1e293b;
        margin-bottom: 18px;
        font-weight: 500;
    }

    /* Botones */
    .btn-medical {
        background-color: #0284c7;
        color: white;
        border: 1px solid #0284c7;
        border-radius: 4px;
        font-weight: 600;
        transition: background-color 0.2s;
    }

        .btn-medical:hover {
            background-color: #0369a1;
            color: white;
            box-shadow: 0 4px 6px rgba(2, 132, 199, 0.1);
        }

    .btn-outline-danger-medical {
        color: #ef4444;
        border: 1px solid #fca5a5;
        background-color: transparent;
        font-weight: 600;
        border-radius: 4px;
        transition: all 0.2s;
    }

        .btn-outline-danger-medical:hover {
            background-color: #fef2f2;
            border-color: #ef4444;
        }
</style>

<div class="container py-4">
    <!-- Botón de regreso -->
    <a asp-action="Index" class="back-link">
        &larr; Volver al Catálogo de Pacientes
    </a>

    <div class="row">
        <!-- Columna Izquierda: Foto de Perfil y Datos Principales -->
        <div class="col-lg-4">
            <div class="clinic-card text-center">
                <div class="avatar-container">
                    <!-- Se lee mediante reflexión para evitar errores si tu entidad no define Foto o ImagenUrl -->
                    <img src="@(Model.GetType().GetProperty("ImagenUrl") != null ? Model.GetType().GetProperty("ImagenUrl").GetValue(Model) : "https://cdn-icons-png.flaticon.com/512/3135/3135715.png")"
                         alt="Paciente"
                         style="width: 140px; height: 140px; object-fit: contain; border-radius: 50%; background-color: #f8fafc; border: 3px solid #e2e8f0; padding: 5px;" />

                    <h3 class="mt-3 mb-2 font-weight-bold" style="color: #0f172a;">@Model.Nombre @Model.Apellido</h3>
                </div>

                <div class="text-start">
                    <div class="detail-label">Número de Registro ID</div>
                    <div class="detail-value">#@Model.Id</div>

                    <div class="detail-label">Fecha de Nacimiento</div>
                    <div class="detail-value">
                        @(Model.GetType().GetProperty("FechaNacimiento") != null ? string.Format("{0:dd/MM/yyyy}", Model.GetType().GetProperty("FechaNacimiento").GetValue(Model)) : "No disponible")
                    </div>
                </div>
            </div>
        </div>

        <!-- Columna Derecha: Información de Contacto e Historial Clínico -->
        <div class="col-lg-8">
            <div class="clinic-card">
                <h3 class="section-title">Información de Contacto</h3>

                <div class="row">
                    <div class="col-md-6">
                        <div class="detail-label">Correo Electrónico</div>
                        <div class="detail-value">
                            @(Model.GetType().GetProperty("Email") != null ? Model.GetType().GetProperty("Email").GetValue(Model) : "Sin registrar")
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="detail-label">Teléfono de Contacto</div>
                        <div class="detail-value">
                            @(Model.GetType().GetProperty("Telefono") != null ? Model.GetType().GetProperty("Telefono").GetValue(Model) : "Sin registrar")
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-12">
                        <div class="detail-label">Dirección Residencial</div>
                        <div class="detail-value">
                            @(Model.GetType().GetProperty("Direccion") != null ? Model.GetType().GetProperty("Direccion").GetValue(Model) : "No especificada")
                        </div>
                    </div>
                </div>

                <h3 class="section-title">Ficha y Expediente Médico</h3>

                <div class="row">
                    <div class="col-md-6">
                        <div class="detail-label">Tipo de Sangre</div>
                        <div class="detail-value">
                            @(Model.GetType().GetProperty("TipoSangre") != null ? Model.GetType().GetProperty("TipoSangre").GetValue(Model) : "O Positivo (O+)")
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="detail-label">Alergias Detectadas</div>
                        <div class="detail-value text-danger" style="font-weight: 600;">
                            @(Model.GetType().GetProperty("Alergias") != null ? Model.GetType().GetProperty("Alergias").GetValue(Model) : "Ninguna reportada")
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-12">
                        <div class="detail-label">Observaciones y Diagnóstico Inicial</div>
                        <div class="detail-value text-muted" style="line-height: 1.6; font-size: 0.95rem; white-space: pre-line;">
                            @(Model.GetType().GetProperty("Observaciones") != null ? Model.GetType().GetProperty("Observaciones").GetValue(Model) : "No hay notas adicionales en el historial clínico actual de este paciente.")
                        </div>
                    </div>
                </div>

                <!-- Acciones del Registro -->
                <div class="d-flex justify-content-end gap-2 mt-4 pt-4 border-top" style="border-top: 1px solid #f1f5f9 !important;">
                    <a asp-action="Editar" asp-route-id="@Model.Id" class="btn btn-medical px-4 py-2" style="margin-right: 10px;">
                        Editar Expediente
                    </a>
                    <a asp-action="Eliminar" asp-route-id="@Model.Id" class="btn btn-outline-danger-medical px-4 py-2">
                        Dar de Baja
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>