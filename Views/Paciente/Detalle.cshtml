@model CitasApp.Models.Paciente

<style>
    body {
        background-color: #0a0a0a !important;
        color: #d1c7bd;
        font-family: 'Courier New', Courier, monospace;
    }

    .back-link {
        color: #8b0000;
        text-decoration: none;
        font-weight: bold;
        display: inline-flex;
        align-items: center;
        margin-bottom: 25px;
        transition: color 0.3s, text-shadow 0.3s;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

        .back-link:hover {
            color: #ff0000;
            text-decoration: none;
            text-shadow: 0 0 8px #ff0000;
        }

    .clinic-card {
        background: #121212;
        border: 2px solid #3a1f1f;
        border-radius: 4px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.9), inset 0 0 15px rgba(139, 0, 0, 0.15);
        padding: 30px;
        margin-bottom: 30px;
    }

    .section-title {
        color: #8b0000;
        font-size: 1.3rem;
        font-weight: 700;
        border-bottom: 2px solid #5a0000;
        padding-bottom: 8px;
        margin-top: 10px;
        margin-bottom: 20px;
        text-transform: uppercase;
        letter-spacing: 1.5px;
    }

    .avatar-container {
        text-align: center;
        border-bottom: 1px solid #3a1f1f;
        padding-bottom: 20px;
        margin-bottom: 20px;
        position: relative;
        overflow: hidden;
    }

        .avatar-container img {
            filter: grayscale(75%) contrast(125%) brightness(90%);
            border: 3px solid #8b0000 !important;
            background-color: #1a1a1a !important;
            box-shadow: 0 0 15px rgba(139, 0, 0, 0.3);
            padding: 5px;
            transition: filter 0.3s;
            position: relative;
            z-index: 2;
        }

            .avatar-container img:hover {
                filter: grayscale(0%) contrast(110%);
            }

        /* Espiral Palpitante (Efecto Latido Doble) */
        .avatar-container::after {
            content: "";
            position: absolute;
            top: 50%;
            left: 50%;
            width: 170px;
            height: 170px;
            transform: translate(-50%, -50%) scale(1);
            opacity: 0.12;
            background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><path d='M 50 50 C 49 47, 53 47, 53 51 C 53 56, 46 56, 45 49 C 44 40, 56 39, 58 49 C 60 62, 41 63, 38 49 C 34 31, 59 28, 63 47 C 67 71, 33 71, 29 48 C 23 18, 67 13, 71 47 C 76 83, 21 82, 16 46' fill='none' stroke='%23ff0000' stroke-width='4' stroke-linecap='round'/></svg>");
            background-size: contain;
            background-repeat: no-repeat;
            pointer-events: none;
            z-index: 1;
            animation: heartbeatSpiral 2.5s infinite ease-in-out;
        }

    @@keyframes heartbeatSpiral {
        0%, 100% {
            transform: translate(-50%, -50%) scale(0.9);
            opacity: 0.1;
        }

        14% {
            transform: translate(-50%, -50%) scale(1.18);
            opacity: 0.35;
            filter: drop-shadow(0 0 8px rgba(255,0,0,0.5));
        }

        28% {
            transform: translate(-50%, -50%) scale(1.0);
            opacity: 0.2;
        }

        42% {
            transform: translate(-50%, -50%) scale(1.24);
            opacity: 0.38;
            filter: drop-shadow(0 0 12px rgba(255,0,0,0.6));
        }

        70% {
            transform: translate(-50%, -50%) scale(0.9);
            opacity: 0.1;
        }
    }

    .detail-label {
        font-size: 0.8rem;
        text-transform: uppercase;
        color: #8a8075;
        font-weight: 700;
        margin-bottom: 3px;
        letter-spacing: 1px;
    }

    .detail-value {
        font-size: 1rem;
        color: #d1c7bd;
        margin-bottom: 18px;
        font-weight: 500;
    }

    .btn-medical {
        background-color: #8b0000;
        color: #ffffff;
        border: 1px solid #5a0000;
        border-radius: 2px;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s;
    }

        .btn-medical:hover {
            background-color: #ff0000;
            color: #000000;
            border-color: #ff0000;
            box-shadow: 0 0 12px rgba(255, 0, 0, 0.6);
        }

    .btn-outline-danger-medical {
        color: #ff3333;
        border: 1px solid #8b0000;
        background-color: #1a0a0a;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 1px;
        border-radius: 2px;
        transition: all 0.3s;
    }

        .btn-outline-danger-medical:hover {
            background-color: #ff0000;
            color: #000000;
            border-color: #ff0000;
            box-shadow: 0 0 15px rgba(255, 0, 0, 0.8);
        }
</style>

<div class="container py-4">
    <a asp-action="Index" class="back-link">
        &larr; Volver al Registro de Sujetos
    </a>

    <div class="row">
        <div class="col-lg-4">
            <div class="clinic-card text-center">
                <div class="avatar-container">
                    <img src="@(Model.GetType().GetProperty("ImagenUrl") != null ? Model.GetType().GetProperty("ImagenUrl").GetValue(Model) : "https://cdn-icons-png.flaticon.com/512/3135/3135715.png")"
                         alt="Sujeto"
                         style="width: 140px; height: 140px; object-fit: contain; border-radius: 50%;" />

                    <h3 class="mt-3 mb-2 font-weight-bold" style="color: #f1f1f1; letter-spacing: 1px;">@Model.Nombre @Model.Apellido</h3>
                </div>

                <div class="text-start">
                    <div class="detail-label">Número de Registro ID</div>
                    <div class="detail-value" style="font-weight: 700; color: #ff3333;">#@Model.Id</div>

                    <div class="detail-label">Fecha de Nacimiento</div>
                    <div class="detail-value">
                        @(Model.GetType().GetProperty("FechaNacimiento") != null ? string.Format("{0:dd/MM/yyyy}", Model.GetType().GetProperty("FechaNacimiento").GetValue(Model)) : "No disponible")
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="clinic-card">
                <h3 class="section-title">Vías de Localización</h3>

                <div class="row">
                    <div class="col-md-6">
                        <div class="detail-label">Correo de Red</div>
                        <div class="detail-value">
                            @(Model.GetType().GetProperty("Email") != null ? Model.GetType().GetProperty("Email").GetValue(Model) : "Sin registrar")
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="detail-label">Línea de Contacto</div>
                        <div class="detail-value">
                            @(Model.GetType().GetProperty("Telefono") != null ? Model.GetType().GetProperty("Telefono").GetValue(Model) : "Sin registrar")
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-12">
                        <div class="detail-label">Último Paradero Conocido</div>
                        <div class="detail-value">
                            @(Model.GetType().GetProperty("Direccion") != null ? Model.GetType().GetProperty("Direccion").GetValue(Model) : "No especificada")
                        </div>
                    </div>
                </div>

                <h3 class="section-title">Expediente de Pruebas y Diagnóstico</h3>

                <div class="row">
                    <div class="col-md-6">
                        <div class="detail-label">Tipo de Sangre</div>
                        <div class="detail-value" style="color: #ff3333; font-weight: 700;">
                            @(Model.GetType().GetProperty("TipoSangre") != null ? Model.GetType().GetProperty("TipoSangre").GetValue(Model) : "O Positivo (O+)")
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="detail-label">Debilidades Clínicas / Alergias</div>
                        <div class="detail-value text-danger" style="font-weight: 700;">
                            @(Model.GetType().GetProperty("Alergias") != null ? Model.GetType().GetProperty("Alergias").GetValue(Model) : "Ninguna reportada")
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-12">
                        <div class="detail-label">Observaciones y Diagnóstico Inicial</div>
                        <div class="detail-value text-muted" style="line-height: 1.6; font-size: 0.95rem; color: #8a8075 !important;">
                            @(Model.GetType().GetProperty("Observaciones") != null ? Model.GetType().GetProperty("Observaciones").GetValue(Model) : "No hay observaciones registradas en esta ficha.")
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4 pt-4 border-top" style="border-top: 1px solid #3a1f1f !important;">
                    <a asp-action="Editar" asp-route-id="@Model.Id" class="btn btn-medical px-4 py-2" style="margin-right: 10px;">
                        Editar Expediente
                    </a>
                    <a asp-action="Eliminar" asp-route-id="@Model.Id" class="btn btn-outline-danger-medical px-4 py-2">
                        Archivar Registro
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>