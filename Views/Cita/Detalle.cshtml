@model CitasApp.Models.Cita

<style>
    body {
        background-color: #0a0a0a !important;
        color: #d1c7bd;
        font-family: 'Courier New', Courier, monospace;
    }

    .back-link {
        color: #8b0000;
        text-decoration: none;
        font-weight: bold;
        display: inline-flex;
        align-items: center;
        margin-bottom: 25px;
        transition: color 0.3s, text-shadow 0.3s;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

        .back-link:hover {
            color: #ff0000;
            text-decoration: none;
            text-shadow: 0 0 8px #ff0000;
        }

    .clinic-card {
        background: #121212;
        border: 2px solid #3a1f1f;
        border-radius: 4px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.9), inset 0 0 15px rgba(139, 0, 0, 0.15);
        padding: 30px;
        margin-bottom: 30px;
    }

    .section-title {
        color: #8b0000;
        font-size: 1.3rem;
        font-weight: 700;
        border-bottom: 2px solid #5a0000;
        padding-bottom: 8px;
        margin-top: 10px;
        margin-bottom: 20px;
        text-transform: uppercase;
        letter-spacing: 1.5px;
    }

    .avatar-card-top {
        text-align: center;
        border-bottom: 1px solid #3a1f1f;
        padding-bottom: 20px;
        margin-bottom: 20px;
        position: relative;
        overflow: hidden;
    }

        .avatar-card-top img {
            filter: grayscale(80%) contrast(140%) brightness(85%);
            transition: filter 0.3s;
            position: relative;
            z-index: 2;
        }

            .avatar-card-top img:hover {
                filter: grayscale(20%) contrast(110%);
            }

        /* Espiral Palpitante (Efecto Latido Doble) */
        .avatar-card-top::after {
            content: "";
            position: absolute;
            top: 50%;
            left: 50%;
            width: 170px;
            height: 170px;
            transform: translate(-50%, -50%) scale(1);
            opacity: 0.12;
            background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><path d='M 50 50 C 49 47, 53 47, 53 51 C 53 56, 46 56, 45 49 C 44 40, 56 39, 58 49 C 60 62, 41 63, 38 49 C 34 31, 59 28, 63 47 C 67 71, 33 71, 29 48 C 23 18, 67 13, 71 47 C 76 83, 21 82, 16 46' fill='none' stroke='%23ff0000' stroke-width='4' stroke-linecap='round'/></svg>");
            background-size: contain;
            background-repeat: no-repeat;
            pointer-events: none;
            z-index: 1;
            animation: heartbeatSpiral 2.5s infinite ease-in-out;
        }

    @@keyframes heartbeatSpiral {
        0%, 100% {
            transform: translate(-50%, -50%) scale(0.9);
            opacity: 0.1;
        }

        14% {
            transform: translate(-50%, -50%) scale(1.18);
            opacity: 0.35;
            filter: drop-shadow(0 0 8px rgba(255,0,0,0.5));
        }

        28% {
            transform: translate(-50%, -50%) scale(1.0);
            opacity: 0.2;
        }

        42% {
            transform: translate(-50%, -50%) scale(1.24);
            opacity: 0.38;
            filter: drop-shadow(0 0 12px rgba(255,0,0,0.6));
        }

        70% {
            transform: translate(-50%, -50%) scale(0.9);
            opacity: 0.1;
        }
    }

    .badge-scheduled {
        background-color: #2b1a0a;
        color: #ffaa00;
        border: 1px solid #ffaa00;
        padding: 6px 14px;
        border-radius: 2px;
        font-weight: bold;
        font-size: 0.85rem;
        text-transform: uppercase;
        text-shadow: 0 0 5px #ffaa00;
        letter-spacing: 1px;
    }

    .badge-completed {
        background-color: #0d200d;
        color: #00ff00;
        border: 1px solid #00ff00;
        padding: 6px 14px;
        border-radius: 2px;
        font-weight: bold;
        font-size: 0.85rem;
        text-transform: uppercase;
        text-shadow: 0 0 5px #00ff00;
        letter-spacing: 1px;
    }

    .badge-canceled {
        background-color: #2b0d0d;
        color: #ff3333;
        border: 1px solid #ff3333;
        padding: 6px 14px;
        border-radius: 2px;
        font-weight: bold;
        font-size: 0.85rem;
        text-transform: uppercase;
        text-shadow: 0 0 5px #ff3333;
        letter-spacing: 1px;
    }

    .detail-label {
        font-size: 0.8rem;
        text-transform: uppercase;
        color: #8a8075;
        font-weight: 700;
        margin-bottom: 3px;
        letter-spacing: 1px;
    }

    .detail-value {
        font-size: 1rem;
        color: #d1c7bd;
        margin-bottom: 18px;
        font-weight: 500;
    }

    .btn-medical {
        background-color: #8b0000;
        color: #ffffff;
        border: 1px solid #5a0000;
        border-radius: 2px;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s;
    }

        .btn-medical:hover {
            background-color: #ff0000;
            color: #000000;
            border-color: #ff0000;
            box-shadow: 0 0 12px rgba(255, 0, 0, 0.6);
        }

    .btn-outline-danger-medical {
        color: #ff3333;
        border: 1px solid #8b0000;
        background-color: #1a0a0a;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 1px;
        border-radius: 2px;
        transition: all 0.3s;
    }

        .btn-outline-danger-medical:hover {
            background-color: #ff0000;
            color: #000000;
            border-color: #ff0000;
            box-shadow: 0 0 15px rgba(255, 0, 0, 0.8);
        }
</style>

<div class="container py-4">
    <!-- Botón de regreso -->
    <a asp-action="Index" class="back-link">
        &larr; Volver al Panel de Sesiones
    </a>

    <div class="row">
        <!-- Columna Izquierda: Información General de la Cita -->
        <div class="col-lg-4">
            <div class="clinic-card text-center">
                <div class="avatar-card-top" style="border-bottom: 1px solid #3a1f1f !important;">
                    <img src="https://cdn-icons-png.flaticon.com/512/3652/3652191.png" alt="Reloj" style="width: 80px; height: 80px; object-fit: contain; margin-bottom: 15px;" />
                    <h4 class="font-weight-bold" style="color: #f1f1f1; letter-spacing: 1px;">Detalle de Sesión</h4>

                    @{
                        var estado = Model.GetType().GetProperty("Estado")?.GetValue(Model)?.ToString() ?? "Pendiente";
                        var badgeClass = "badge-scheduled";
                        if (estado == "Completada" || estado == "Finalizada" || estado == "Confirmado")
                        {
                            badgeClass = "badge-completed";
                        }
                        else if (estado == "Cancelada")
                        {
                            badgeClass = "badge-canceled";
                        }
                    }
                    <span class="@badgeClass">@estado</span>
                </div>

                <div class="text-start">
                    <div class="detail-label">ID de Registro de Sesión</div>
                    <div class="detail-value" style="color: #ff3333;">#@Model.Id</div>

                    <div class="detail-label">Fecha de Ejecución</div>
                    <div class="detail-value" style="font-weight: 700; color: #ff3333;">
                        @{
                            var fechaVal = Model.GetType().GetProperty("Fecha")?.GetValue(Model);
                            string fechaStr = "Fecha No Registrada";
                            if (fechaVal != null)
                            {
                                if (fechaVal is DateOnly dateOnly)
                                {
                                    fechaStr = dateOnly.ToString("dd/MM/yyyy");
                                }
                                else
                                {
                                    fechaStr = string.Format("{0:dd/MM/yyyy}", fechaVal);
                                }
                            }
                        }
                        @fechaStr
                    </div>

                    <div class="detail-label">Hora Límite (El tiempo corre)</div>
                    <div class="detail-value" style="font-weight: 700; color: #ff3333;">
                        @{
                            var horaVal = Model.GetType().GetProperty("Hora")?.GetValue(Model);
                            string horaStr = "Hora No Registrada";
                            if (horaVal != null)
                            {
                                if (horaVal is TimeOnly timeOnly)
                                {
                                    horaStr = timeOnly.ToString("HH:mm");
                                }
                                else
                                {
                                    horaStr = string.Format("{0:HH:mm}", horaVal);
                                }
                            }
                        }
                        @horaStr
                    </div>
                </div>
            </div>
        </div>

        <!-- Columna Derecha: Información Profesional y Médica -->
        <div class="col-lg-8">
            <div class="clinic-card">
                <h3 class="section-title">Identificación de Sujetos</h3>

                <div class="row">
                    <!-- Paciente -->
                    <div class="col-md-6">
                        <div class="detail-label">Sujeto de Pruebas</div>
                        <div class="detail-value" style="font-weight: 600;">
                            @{
                                var pacienteObj = Model.GetType().GetProperty("Paciente")?.GetValue(Model);
                                string pacienteNombre = "Ana";
                                if (pacienteObj != null)
                                {
                                    var nom = pacienteObj.GetType().GetProperty("Nombre")?.GetValue(pacienteObj)?.ToString();
                                    var ape = pacienteObj.GetType().GetProperty("Apellido")?.GetValue(pacienteObj)?.ToString();
                                    pacienteNombre = $"{nom} {ape}".Trim();
                                }
                            }
                            @pacienteNombre
                        </div>
                    </div>

                    <!-- Médico Tratante -->
                    <div class="col-md-6">
                        <div class="detail-label">Supervisor a Cargo</div>
                        <div class="detail-value" style="font-weight: 600;">
                            @{
                                var medicoObj = Model.GetType().GetProperty("Medico")?.GetValue(Model);
                                string medicoNombre = "Dr. Carlos Reyes";
                                string especialidad = "Medicina General";
                                if (medicoObj != null)
                                {
                                    medicoNombre = medicoObj.GetType().GetProperty("Nombre")?.GetValue(medicoObj)?.ToString() ?? "No asignado";
                                    especialidad = medicoObj.GetType().GetProperty("Especialidad")?.GetValue(medicoObj)?.ToString() ?? "";
                                }
                            }
                            @medicoNombre @(!string.IsNullOrEmpty(especialidad) ? $"({especialidad})" : "")
                        </div>
                    </div>
                </div>

                <h3 class="section-title">Especificaciones de la Sesión</h3>

                <div class="row">
                    <!-- Consultorio -->
                    <div class="col-md-6">
                        <div class="detail-label">Cámara / Consultorio Asignado</div>
                        <div class="detail-value" style="color: #ff3333;">
                            @(Model.GetType().GetProperty("Consultorio") != null ? Model.GetType().GetProperty("Consultorio").GetValue(Model) : "N/A")
                        </div>
                    </div>

                    <!-- Motivo -->
                    <div class="col-md-6">
                        <div class="detail-label">Motivo del Encuentro</div>
                        <div class="detail-value text-muted" style="line-height: 1.6; color: #8a8075 !important;">
                            @(Model.GetType().GetProperty("Motivo") != null ? Model.GetType().GetProperty("Motivo").GetValue(Model) : "Consulta estándar")
                        </div>
                    </div>
                </div>

                <!-- Observaciones -->
                <div class="row">
                    <div class="col-12">
                        <div class="detail-label">Observaciones y Dictamen Clínico</div>
                        <div class="detail-value text-muted" style="line-height: 1.6; font-size: 0.95rem; color: #8a8075 !important;">
                            @(Model.GetType().GetProperty("Observaciones") != null ? Model.GetType().GetProperty("Observaciones").GetValue(Model) : "No hay observaciones registradas.")
                        </div>
                    </div>
                </div>

                <!-- Acciones del Registro -->
                <div class="d-flex justify-content-end gap-2 mt-4 pt-4 border-top" style="border-top: 1px solid #3a1f1f !important;">
                    <a asp-action="Editar" asp-route-id="@Model.Id" class="btn btn-medical px-4 py-2" style="margin-right: 10px;">
                        Modificar Parámetros
                    </a>
                    <a asp-action="Eliminar" asp-route-id="@Model.Id" class="btn btn-outline-danger-medical px-4 py-2">
                        Anular Sesión
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>